import { Hono } from 'hono';
import { cors } from 'hono/cors';
import { db, users } from "../db";

const app = new Hono();

// Enable CORS for mobile apps
app.use('/*', cors({
  origin: ['http://localhost:3000', 'http://localhost:3002', 'capacitor://localhost', 'ionic://localhost'],
  credentials: true,
}));

// Health check
app.get('/', (c) => {
  return c.json({ message: 'Coder API is running' });
});

// Test database connection
app.get('/test-db', async (c) => {
  try {
    const allUsers = await db.select().from(users);
    return c.json({ 
      message: 'Database connection working',
      userCount: allUsers.length,
      users: allUsers.map(u => ({ id: u.id, email: u.email, name: u.name }))
    });
  } catch (error) {
    console.error('Database test error:', error);
    return c.json({ error: 'Database connection failed', details: error instanceof Error ? error.message : 'Unknown error' }, 500);
  }
});

export default app; 